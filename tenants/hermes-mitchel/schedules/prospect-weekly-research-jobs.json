      "required_tools": [
        "delegate_task",
        "claim_prospect_research_batch",
        "store_prospect_research_evidence",
        "list_prospect_research_evidence"
      ],
      "runbook": "tenants/hermes-mitchel/runbooks/prospect-deep-research.md"
    }
  ]
}
