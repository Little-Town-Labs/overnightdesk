{
  "schema_version": 1,
  "name": "prospect-weekly-research-jobs",
  "install_status": "template_only",
  "approval_required": true,
  "timezone": "America/Chicago",
  "schedule_local": "Saturday 23:00 America/Chicago",
  "notes": [
    "Disabled-by-default template. Do not install or enable in production until migration 055, Trevor MCP deploy, on-demand smokes, and explicit operator approval are complete.",
