        "kind": "weekly_local",
        "day_of_week": "saturday",
        "time": "23:00",
        "timezone": "America/Chicago"
      },
      "origin": "specs/011-prospect-deep-research",
      "workdir": "/opt/data/mcp-servers/trevor-db",
      "scope": {
        "prospects": "missing_email_first",
        "batch_limit": 50,
        "outbound_sent": false
      },
      "required_tools": [
        "seed_prospect_email_enrichment_queue",
        "process_prospect_email_enrichment_batch",
        "get_prospect_email_enrichment_summary"
      ],
      "runbook": "tenants/hermes-mitchel/runbooks/prospect-deep-research.md"
    },
    {
      "id": "trevor-prospect-deep-research-weekly",
      "name": "Trevor prospect deep research weekly pass",
      "enabled": false,
      "schedule": {
        "kind": "weekly_local",
        "day_of_week": "saturday",
        "time": "23:00",
        "timezone": "America/Chicago"
      },
      "origin": "specs/011-prospect-deep-research",
      "workdir": "/opt/data/mcp-servers/trevor-db",
      "scope": {
        "prospects": "all_prospects_missing_email_first",
