# Neon DB (required — stores waitlist signups)
DATABASE_URL=postgresql://...@ep-xxx.us-east-2.aws.neon.tech/overnightdesk?sslmode=require

# App
NEXT_PUBLIC_APP_URL=https://overnightdesk.com

# Better Auth (required for authentication)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Hermes dashboard OIDC rollout gate. The issuer is derived from
# BETTER_AUTH_URL plus Better Auth's /api/auth base path.
# Keep false until one isolated tenant has completed canary qualification.
HERMES_DASHBOARD_OIDC_ENABLED=false
# Comma-separated existing tenant IDs approved for isolated canary operations.
# This does not enable OIDC provisioning for new customer instances.
HERMES_DASHBOARD_OIDC_CANARY_TENANT_IDS=

# Walter / Tenet 0 membership authority. Legacy is the safe default and does
# no canonical lookup. Compare keeps the legacy owner authoritative and
# requires its exact confirmation. Canonical makes active, unexpired canonical
# membership authoritative and requires a separate exact confirmation.
WALTER_MEMBERSHIP_AUTH_MODE=legacy
WALTER_MEMBERSHIP_COMPARISON_CONFIRM=
WALTER_MEMBERSHIP_CANONICAL_CONFIRM=

# Canonical identity observation gate. Legacy remains authoritative in both
# supported modes; compare adds metadata-only shadow reads and audit events.
CANONICAL_IDENTITY_READ_MODE=legacy

# Test database (Neon branch — for integration tests)
DATABASE_TEST_URL=postgresql://...@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Resend (required for transactional email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=OvernightDesk <onboarding@resend.dev>

# Stripe (required for billing)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# Billing controls
NEXT_PUBLIC_BILLING_ENABLED=true
ADMIN_EMAILS=gary@littletownlabs.com

# Invite-only registration (comma-separated, during early access)
INVITED_EMAILS=

# Provisioner (required for instance provisioning)
PROVISIONER_URL=https://api.overnightdesk.com
PROVISIONER_SECRET=generate-with-openssl-rand-base64-32

# Fleet monitoring (required for health checks and notifications)
CRON_SECRET=
OWNER_TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_CHAT_ID=
